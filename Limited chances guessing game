#include <stdio.h>

int main()
{
    int secret = 7, guess, chances = 3;

    while(chances > 0)
    {
        scanf("%d",&guess);

        if(guess == secret)
        {
            printf("You Win!");
            break;
        }

        chances--;

        printf("Wrong Guess\n");
        printf("Remaining Chances = %d\n", chances);
    }

    return 0;
}
