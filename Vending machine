#include <stdio.h>

int main()
{
    int choice, qty, total;

    printf("1. Pepsi - 40\n");
    printf("2. Chips - 20\n");
    printf("3. Chocolate - 30\n");

    printf("Enter Choice: ");
    scanf("%d",&choice);

    printf("Enter Quantity: ");
    scanf("%d",&qty);

    switch(choice)
    {
        case 1: total = qty * 40; break;
        case 2: total = qty * 20; break;
        case 3: total = qty * 30; break;
        default: printf("Invalid Choice"); return 0;
    }

    printf("Total Bill = %d",total);

    return 0;
}
