#include <stdio.h>

int main()
{
    int choice;
    float balance = 5000, amount;

    while(1)
    {
        printf("\n1.Balance\n2.Deposit\n3.Withdraw\n4.Exit\n");
        scanf("%d",&choice);

        if(choice == 1)
        {
            printf("Balance = %.2f\n", balance);
        }
        else if(choice == 2)
        {
            scanf("%f",&amount);
            balance += amount;
        }
        else if(choice == 3)
        {
            scanf("%f",&amount);

            if(amount <= balance)
                balance -= amount;
            else
                printf("Insufficient Balance\n");
        }
        else if(choice == 4)
        {
            break;
        }
    }

    return 0;
}
