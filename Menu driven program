#include <stdio.h>

int main()
{
    int choice;

    while(1)
    {
        printf("\n1.Play\n2.Settings\n3.Exit\n");
        scanf("%d",&choice);

        if(choice == 1)
            printf("Game Started\n");

        else if(choice == 2)
            printf("Settings Opened\n");

        else if(choice == 3)
        {
            printf("Exiting...");
            break;
        }

        else
            printf("Invalid Choice\n");
    }

    return 0;
}
