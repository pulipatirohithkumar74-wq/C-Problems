#include <stdio.h>

int main()
{
    int choice, qty;
    float total = 0;

    printf("1. Apple  - ₹50\n");
    printf("2. Milk   - ₹30\n");
    printf("3. Bread  - ₹40\n");

    printf("Choose Item: ");
    scanf("%d",&choice);

    printf("Quantity: ");
    scanf("%d",&qty);

    if(choice == 1)
        total = qty * 50;
    else if(choice == 2)
        total = qty * 30;
    else if(choice == 3)
        total = qty * 40;

    printf("Total Bill = ₹%.2f", total);

    return 0;
}
