#include <stdio.h>

int main()
{
    float weight, height, bmi;

    scanf("%f %f",&weight,&height);

    bmi = weight / (height * height);

    printf("BMI = %.2f\n", bmi);

    if(bmi < 18.5)
        printf("Underweight");

    else if(bmi < 25)
        printf("Normal");

    else
        printf("Overweight");

    return 0;
}
