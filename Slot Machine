#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main()
{
    srand(time(0));

    int a = rand()%10;
    int b = rand()%10;
    int c = rand()%10;

    printf("%d %d %d\n",a,b,c);

    if(a==b && b==c)
        printf("JACKPOT!");
    else if(a==b || b==c || a==c)
        printf("Small Prize");
    else
        printf("Try Again");

    return 0;
}
