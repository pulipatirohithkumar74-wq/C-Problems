#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main()
{
    int secret, guess, attempts = 5, diff;
    char choice;

    srand(time(0));

    do
    {
        secret = rand() % 100 + 1;
        attempts = 5;

        printf("\n=== NUMBER GUESSING GAME ===\n");
        printf("Guess a number between 1 and 100\n");

        while(attempts > 0)
        {
            printf("\nAttempts Left: %d", attempts);
            printf("\nEnter your guess: ");
            scanf("%d", &guess);

            diff = guess - secret;
            if(diff < 0)
                diff = -diff;

            if(guess == secret)
            {
                printf("🥳 Congratulations! You guessed the number!\n");
                break;
            }
            else if(diff <= 3)
            {
                printf("🔥 Very Close!\n");
            }
            else if(diff <= 10)
            {
                printf("🙂 Close!\n");
            }
            else
            {
                printf("❄️ Far Away!\n");
            }

            if(guess < secret)
                printf("Hint: Try a BIGGER number.\n");
            else
                printf("Hint: Try a SMALLER number.\n");

            attempts--;
        }

        if(attempts == 0)
        {
            printf("\n😢 Game Over!");
            printf("\nThe number was %d\n", secret);
        }

        printf("\nPlay Again? (y/n): ");
        scanf(" %c", &choice);

    } while(choice == 'y' || choice == 'Y');

    printf("\nThanks for Playing! 🎮\n");

    return 0;
}
