#include <stdio.h>

int main()
{
    int n, temp, rem, sum=0, fact, i;

    scanf("%d",&n);
    temp = n;

    while(n>0)
    {
        rem = n%10;
        fact = 1;

        for(i=1;i<=rem;i++)
            fact *= i;

        sum += fact;
        n /= 10;
    }

    if(sum == temp)
        printf("Peterson Number");
    else
        printf("Not Peterson");

    return 0;
}
